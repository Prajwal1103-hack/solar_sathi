# Solar Sathi MCP Server Configuration

# LLM API Keys (choose one)
# For OpenAI-based LLM calls in generate_homeowner_report prompt
OPENAI_API_KEY=sk-...

# Alternatively, use Google Gemini
# GEMINI_API_KEY=AIza...

# Note: Open-Meteo API (used for solar irradiance) requires no key

# Optional: Custom Solar Parameters
# COST_PER_KW_INR=62500
# DEFAULT_PANEL_EFFICIENCY=0.18
# DEFAULT_SYSTEM_EFFICIENCY=0.75
